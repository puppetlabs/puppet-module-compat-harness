{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/modules.schema.json",
  "title": "Puppet Module Tester modules.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "modules"
  ],
  "properties": {
    "modules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "repo"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9_.-]+$"
          },
          "repo": {
            "type": "string",
            "minLength": 1,
            "pattern": "^(https://|git@).+"
          },
          "ref": {
            "type": "string",
            "minLength": 1
          },
          "os": {
            "type": "string",
            "enum": [
              "ubuntu-latest",
              "windows-latest",
              "macos-latest"
            ]
          },
          "prereqs": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "apt": {
                "$ref": "#/$defs/packageList"
              },
              "dnf": {
                "$ref": "#/$defs/packageList"
              },
              "yum": {
                "$ref": "#/$defs/packageList"
              },
              "apk": {
                "$ref": "#/$defs/packageList"
              },
              "brew": {
                "$ref": "#/$defs/packageList"
              },
              "choco": {
                "$ref": "#/$defs/packageList"
              },
              "pacman": {
                "$ref": "#/$defs/packageList"
              }
            }
          },
          "acceptance": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "enabled"
            ],
            "properties": {
              "enabled": {
                "type": "boolean"
              },
              "targets": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "$ref": "#/$defs/acceptanceTarget"
                }
              }
            },
            "allOf": [
              {
                "if": {
                  "properties": {
                    "enabled": {
                      "const": true
                    }
                  }
                },
                "then": {
                  "required": [
                    "targets"
                  ]
                }
              }
            ]
          }
        }
      }
    }
  },
  "$defs": {
    "acceptanceTarget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "setfile"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "setfile": {
          "type": "string",
          "minLength": 1
        },
        "docker_mode": {
          "type": "string",
          "enum": [
            "sshd",
            "systemd"
          ],
          "default": "sshd"
        }
        },
        "install_puppetserver": {
          "type": "boolean",
          "default": false
        }
      }
    },
    "packageList": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    }
  }
}
