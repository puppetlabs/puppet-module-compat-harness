{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/modules.schema.json",
  "title": "Puppet Module Tester modules.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "modules"
  ],
  "properties": {
    "modules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "repo",
          "acceptance"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9_.-]+$"
          },
          "repo": {
            "type": "string",
            "minLength": 1,
            "pattern": "^(https://|git@).+"
          },
          "ref": {
            "type": "string",
            "minLength": 1
          },
          "deprecated": {
            "type": "boolean",
            "description": "True if the upstream module is no longer maintained (deprecated/archived by its maintainer or on the Forge). Orthogonal to compatibility — a deprecated module can still be fully compatible. Surfaced as a ⚠️ badge and a count in STATUS.md. Defaults to false when absent."
          },
          "os": {
            "type": "string",
            "enum": [
              "ubuntu-latest",
              "windows-latest",
              "macos-latest"
            ]
          },
          "prereqs": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "apt": {
                "$ref": "#/$defs/packageList"
              },
              "dnf": {
                "$ref": "#/$defs/packageList"
              },
              "yum": {
                "$ref": "#/$defs/packageList"
              },
              "apk": {
                "$ref": "#/$defs/packageList"
              },
              "brew": {
                "$ref": "#/$defs/packageList"
              },
              "choco": {
                "$ref": "#/$defs/packageList"
              },
              "pacman": {
                "$ref": "#/$defs/packageList"
              }
            }
          },
          "acceptance": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "enabled",
              "status"
            ],
            "properties": {
              "enabled": {
                "type": "boolean",
                "description": "Whether acceptance tests run in CI for this module. Only enabled modules enter the acceptance matrix (see scripts/build_matrix.rb). Must be true iff status is 'running'."
              },
              "status": {
                "type": "string",
                "enum": [
                  "running",
                  "blocked",
                  "pending",
                  "none"
                ],
                "description": "Acceptance-test disposition. 'running': tests exist upstream and execute in CI. 'blocked': tests exist upstream but cannot run in this harness due to a hard technical limitation (see reason). 'pending': tests exist upstream but are not yet wired into the harness, e.g. Windows-only targets (see reason). 'none': no acceptance tests exist in the upstream repository — unit coverage alone is full coverage (rendered as N/A)."
              },
              "reason": {
                "type": "string",
                "minLength": 1,
                "description": "Required when status is 'blocked' or 'pending': why the acceptance tests do not run in this harness. Serves as the source of truth for the generated acceptance-test audit."
              },
              "targets": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "$ref": "#/$defs/acceptanceTarget"
                }
              }
            },
            "allOf": [
              {
                "if": {
                  "properties": {
                    "enabled": {
                      "const": true
                    }
                  },
                  "required": [
                    "enabled"
                  ]
                },
                "then": {
                  "required": [
                    "targets"
                  ],
                  "properties": {
                    "status": {
                      "const": "running"
                    }
                  }
                }
              },
              {
                "if": {
                  "properties": {
                    "enabled": {
                      "const": false
                    }
                  },
                  "required": [
                    "enabled"
                  ]
                },
                "then": {
                  "properties": {
                    "status": {
                      "enum": [
                        "blocked",
                        "pending",
                        "none"
                      ]
                    }
                  }
                }
              },
              {
                "if": {
                  "properties": {
                    "status": {
                      "enum": [
                        "blocked",
                        "pending"
                      ]
                    }
                  },
                  "required": [
                    "status"
                  ]
                },
                "then": {
                  "required": [
                    "reason"
                  ]
                }
              }
            ]
          }
        }
      }
    }
  },
  "$defs": {
    "acceptanceTarget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "setfile"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "setfile": {
          "type": "string",
          "minLength": 1
        },
        "docker_mode": {
          "type": "string",
          "enum": [
            "sshd",
            "systemd"
          ],
          "default": "sshd"
        },
        "install_puppetserver": {
          "type": "boolean",
          "default": false
        },
        "setup_commands": {
          "type": "array",
          "description": "Additional shell commands appended to docker_image_commands during SUT image build. Use for module-specific SUT preparation (e.g. disabling AppArmor for modules that require it).",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "pre_acceptance_commands": {
          "type": "array",
          "description": "Shell commands run on the host runner before Beaker starts. Use to start external services (e.g. GitLab, databases) that acceptance tests connect to. Commands execute from the cloned module directory.",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "packageList": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    }
  }
}
